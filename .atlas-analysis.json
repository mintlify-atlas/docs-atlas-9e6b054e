    "THorse.Patch(path, callback)",
    "THorse.Head(path, callback)",
    "THorse.All(path, callback)",
    "THorse.Use(callback)",
    "THorse.Use(path, callback)",
    "THorse.Group()",
    "THorse.Route(path)",
    "THorse.Listen(port, host)",
    "THorse.StopListen()",
